# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# Required: OpenRouter API key used by the AI sidebar chat (backend/ai.py).
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Recommended: secret used to sign session JWTs (backend/auth.py).
# If unset, a clearly-marked insecure dev default is used. Required when
# APP_ENV=production — the app refuses to start in production without it.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Optional: deployment environment. "development" (default) or "production".
# In production, session cookies are marked Secure (HTTPS-only) and JWT_SECRET
# becomes mandatory.
APP_ENV=development
